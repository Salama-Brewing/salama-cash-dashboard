# Procountor OAuth2 credentials
# Get these after registering at https://dev.procountor.com
# and having Salama activate the API in Management → Company info → Usage settings

PROCOUNTOR_CLIENT_ID=your_client_id_here
PROCOUNTOR_CLIENT_SECRET=your_client_secret_here

# API user credentials (the "Salama-CashDashboard" user you create in Procountor)
PROCOUNTOR_USERNAME=salama-cashdashboard
PROCOUNTOR_PASSWORD=your_api_user_password_here

# Optional: use test environment (free, provided on developer registration)
# PROCOUNTOR_ENV=test
